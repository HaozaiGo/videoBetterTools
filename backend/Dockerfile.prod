ARG UV_BASE_IMAGE=ghcr.io/astral-sh/uv:python3.12-bookworm-slim
FROM ${UV_BASE_IMAGE}

WORKDIR /app/backend

ARG APT_MIRROR=http://deb.debian.org/debian
ARG APT_SECURITY_MIRROR=http://deb.debian.org/debian-security
ARG PYPI_INDEX_URL=https://pypi.org/simple
ARG UV_SYNC_ARGS=--frozen

RUN printf 'deb %s bookworm main\n' "$APT_MIRROR" > /etc/apt/sources.list \
    && printf 'deb %s bookworm-updates main\n' "$APT_MIRROR" >> /etc/apt/sources.list \
    && printf 'deb %s bookworm-security main\n' "$APT_SECURITY_MIRROR" >> /etc/apt/sources.list \
    && rm -f /etc/apt/sources.list.d/debian.sources \
    && apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY backend/pyproject.toml backend/uv.lock ./
RUN uv sync $UV_SYNC_ARGS --default-index "$PYPI_INDEX_URL"

COPY backend/alembic.ini ./alembic.ini
COPY backend/alembic ./alembic
COPY backend/app ./app
COPY scripts /app/scripts

ENV PATH="/app/backend/.venv/bin:$PATH"

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8010"]
