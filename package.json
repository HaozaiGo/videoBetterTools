{
  "name": "model-plaza",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:api": "uv --directory backend run uvicorn app.main:app --host 0.0.0.0 --port 8010 --reload --reload-dir app",
    "dev:worker": "uv --directory backend run python -m app.worker",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "start": "node server.js"
  },
  "dependencies": {
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
