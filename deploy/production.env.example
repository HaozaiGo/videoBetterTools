# Copy this content into the GitHub Secret named PRODUCTION_ENV and replace
# secrets before deploying.
POSTGRES_DB=model_plaza
POSTGRES_USER=model_plaza
POSTGRES_PASSWORD=replace-with-a-strong-password
AUTH_SECRET=replace-with-a-long-random-secret
ALLOW_DEMO_WITHOUT_AUTH=false
WEB_PORT=8003
WORKER_REPLICAS=8

TASK_JOB_TIMEOUT_SECONDS=7200
STORAGE_BACKEND=local

# Remote GPU worker API.
MODEL_PLAZA_GPU_API_URL=http://32.196.46.122:18081
MODEL_PLAZA_GPU_API_KEY=replace-with-gpu-api-key
MODEL_PLAZA_CALLBACK_URL=http://api:8010/api/provider/callback

